# Common VHS settings for integration tests
# Optimized for testing: faster typing, lower framerate, no decorations

Set Shell bash
Set FontSize 16
Set FontFamily "JetBrains Mono"
Set Width 1200
Set Height 700
Set Padding 15
Set Theme "Dracula"
Set WindowBar Rings

# Faster settings for testing (fewer intermediate frames)
Set TypingSpeed 20ms
Set Framerate 10
